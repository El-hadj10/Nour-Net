# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer .env (il est dans .gitignore)

# URL du webhook Discord pour les alertes zombies haute valeur
# Creer un webhook : Discord > Parametres du serveur > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Score minimum (0-100) pour declencher une alerte Discord
# Par defaut : 60 (configurable aussi via le parametre alert_threshold de la session)
# ALERT_SCORE_THRESHOLD=60

# Port du control port Tor (defaut : 9051)
# Doit etre ouvert dans /etc/tor/torrc : ControlPort 9051
# TOR_CONTROL_PORT=9051
